#!/usr/bin/env python3
import sys
from contextlib import suppress
from pathlib import Path
from string import printable

TRANSLATION_TABLE = {
    **dict(
        zip("–∞–±–≤–≥–і–µ—С–ґ–Ј–Є–є–Ї–ї–Љ–љ–Њ–њ—А—Б—В—Г—Д—Е—Ж—З—И—Й—М—К—Л—Н—О—П", "abvgdeejzijklmnoprstufhchssjjiaua")
    ),
    **dict(
        zip("–Р–С–Т–У–Ф–Х–Б–Ц–Ч–Ш–Щ–Ъ–Ы–Ь–Э–Ю–Я–†–°–Ґ–£–§–•–¶–І–®–©–ђ–™–Ђ–≠–Ѓ–ѓ", "ABVGDEEJZIJKLMNOPRSTUFHCHSSJJIAUA")
    ),
}
SOURCE_SUFFIXES: set[str] = {".txt"}
SUFFIX: str = ".ascii"


def convert(text: str) -> str:
    lines = [
        "".join(
            char
            if char in printable
            else TRANSLATION_TABLE.get(char, f"u{ord(char):04}")
            for char in line
        )
        for line in text.splitlines()
    ]
    return "".join(line + "\n" for line in lines)


def main(script_name: str, *script_args: str):
    for arg in script_args:
        print(convert(Path(arg).read_text()))


if __name__ == "__main__":
    with suppress(KeyboardInterrupt):
        main(sys.argv[0], *sys.argv[1:])
